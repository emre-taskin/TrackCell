@inject Microsoft.Extensions.Options.IOptions<ApiSettings> ApiOptions
@{
    var api = ApiOptions.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackCell MES</title>
    <script>
        // Configuration injected from appsettings.json (ApiSettings section).
        // Update appsettings.json instead of editing URLs in views.
        window.AppConfig = {
            apiBase:     '@Html.Raw(api.BaseUrl)',
            hubUrl:      '@Html.Raw(api.HubUrl)',
            workItems:   '@Html.Raw(api.OperationHistoryUrl)',
            masterData:  '@Html.Raw(api.MasterUrl)',
            part:        '@Html.Raw(api.PartUrl)'
        };
    </script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <header class="glass-header">
            <div class="logo">
                <span class="logo-icon">🔮</span>
                <h1>TrackCell</h1>
            </div>
            <nav class="main-nav">
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" class="nav-link">Operator Entry</a>
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Dashboard" class="nav-link">Kaizen Dashboard</a>
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Factory3D" class="nav-link">3D Factory</a>
            </nav>
        </header>
        
        <main class="@(ViewData["IsFullscreen"] as bool? == true ? "content-fullscreen" : "content-area")">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
